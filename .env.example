# ─────────────────────────────────────────────────────────────────
#  .env.example  –  Copy this file to .env and fill in real values
#  NEVER commit the actual .env file to Git!
# ─────────────────────────────────────────────────────────────────

# ── Google Gemini ──
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY

# ── Deepgram ──
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_API_KEY

# ── Groq ──
GROQ_API_KEY=YOUR_GROQ_API_KEY

# ── Twilio ──
twilio_sid=YOUR_TWILIO_SID
twilio_token=YOUR_TWILIO_TOKEN
YOUR_TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── MongoDB ──
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/connectai

# ── Public URL (used by Twilio webhooks) ──
# For local dev: use ngrok or Cloudflare tunnel URL
# For AWS:       use your EC2 public IP, ALB DNS name, or custom domain
BASE_URL=https://your-public-url-here.com

# ── Optional: Cloudinary credentials ──
