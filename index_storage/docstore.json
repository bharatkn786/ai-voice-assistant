{"docstore/ref_doc_info": {"8f30aa6e-a075-4914-85f6-e9333911418b": {"node_ids": ["8d5fecfd-e899-449e-9d1e-5ff6cbec99f6", "17fc0a98-46e9-43c1-89f2-3f956a9d6a0b", "0182fd2b-0cfc-48a2-abfd-09a9e5267e3a", "8b26fad6-a475-419f-8cbb-7d20d040c1d0", "a6380b11-b49d-42bc-a551-2082784759ea", "b765b7b0-1de8-484d-96b9-de7ab666cd5f", "213aea06-35f3-4f15-9759-c55a8f41185f", "1297b84b-76de-47ec-88b6-3be1d8b21939", "35d08661-35cf-4903-b083-e1924ee80f60", "179feaf5-03fb-4cda-8135-91dddcdd141f", "70347ab9-23e5-43e0-95b5-4322f018b68f", "6e92b174-f6cc-41a6-903f-e40c76e0c6c9", "cdbbd83b-7c30-4848-b9bf-d4a9c9b85ffa", "6d3cc85e-bbb6-4a78-98a6-78d98e5cc2c0"], "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}}}, "docstore/data": {"8d5fecfd-e899-449e-9d1e-5ff6cbec99f6": {"__data__": {"id_": "8d5fecfd-e899-449e-9d1e-5ff6cbec99f6", "embedding": null, "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "8f30aa6e-a075-4914-85f6-e9333911418b", "node_type": "4", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "5ec2623a1e939294ad513db18bb59a532e60c37565fed9956bb7d0aa328cd00f", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "17fc0a98-46e9-43c1-89f2-3f956a9d6a0b", "node_type": "1", "metadata": {}, "hash": "5af11972e54aa8890f5b414b4afbb3c53de276645969494f07f22842d609cc51", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "University Overview & Contact Information\r\n\r\nChitkara University is a government-recognized private university established under The Chitkara University Act by the Punjab State Legislature. It is authorized to award degrees under Sections 2(f) and 22(1) of the UGC Act, 1956, and is recognized among North India\u2019s leading private universities for its industry-integrated programs and global academic collaborations. The university\u2019s vision is to achieve global recognition in promoting academic excellence through interdisciplinary research and innovation. Its mission is to align educational practices with international standards, nurture entrepreneurship and research partnerships globally, and instill strong ethical and professional values among students. Chitkara University operates two main campuses \u2014 one in Punjab, located on the Chandigarh\u2013Patiala National Highway, and another in Himachal Pradesh, situated along the Pinjore\u2013Barotiwala National Highway. For admissions and inquiries, the contact helplines are Chandigarh (95011 05714, 95011 05715), Delhi/NCR (95993 68734), and WhatsApp (98590 00000).", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 1113, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "17fc0a98-46e9-43c1-89f2-3f956a9d6a0b": {"__data__": {"id_": "17fc0a98-46e9-43c1-89f2-3f956a9d6a0b", "embedding": null, "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "8f30aa6e-a075-4914-85f6-e9333911418b", "node_type": "4", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "5ec2623a1e939294ad513db18bb59a532e60c37565fed9956bb7d0aa328cd00f", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "8d5fecfd-e899-449e-9d1e-5ff6cbec99f6", "node_type": "1", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "803a0e44860c154cb3fd903e55b10ecaed3032dd3bd2b7d21eab5a71da8471d4", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "0182fd2b-0cfc-48a2-abfd-09a9e5267e3a", "node_type": "1", "metadata": {}, "hash": "ce38180548052a83f66a501b5fa1feeac0d0e12853a21e3e7cfc0e680938448c", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "The university also offers a missed-call service at 1800 267 1999 and can be contacted via email at admissions@chitkara.edu.in\r\n\r\n\r\n\r\nGeneral Admission Information\r\n\r\nAdmission to all undergraduate programs requires successful completion of Class XII from a recognized board with the specified minimum percentage, depending on the course. Engineering admissions are based on JEE Mains 2025 (January or April sessions), and candidates must have been born on or after October 1, 2003. All B.E. students must possess a personal laptop. Applicants are required to submit their Class X and XII mark sheets, migration certificate, character certificate, Aadhaar card, medical fitness certificate, and, where applicable, the entrance exam rank card. The first-year fee includes a one-time \u20b920,000 charge covering Educational Technology Services (ETS) and Career Advancement Services (CAS). Fees are subject to revision by the university. Students must maintain a minimum of 75% attendance to appear for final examinations.", "mimetype": "text/plain", "start_char_idx": 1114, "end_char_idx": 2129, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "0182fd2b-0cfc-48a2-abfd-09a9e5267e3a": {"__data__": {"id_": "0182fd2b-0cfc-48a2-abfd-09a9e5267e3a", "embedding": null, "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "8f30aa6e-a075-4914-85f6-e9333911418b", "node_type": "4", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "5ec2623a1e939294ad513db18bb59a532e60c37565fed9956bb7d0aa328cd00f", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "17fc0a98-46e9-43c1-89f2-3f956a9d6a0b", "node_type": "1", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "8e2661279e41440a02fe732d63ade4754008e4bd7c0fd6293bc08fd45ae9e86e", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "8b26fad6-a475-419f-8cbb-7d20d040c1d0", "node_type": "1", "metadata": {}, "hash": "61e16fc85769c354bcd8c663ec7023205c7bb911626205a6f8875e855a7b2505", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Students must maintain a minimum of 75% attendance to appear for final examinations. Seat reservations are provided as follows: Punjab campus reserves 15% of seats for Punjab domicile students, while Himachal Pradesh campus reserves 25% for HP domicile students. Reservations for SC/ST/OBC and other categories follow the respective state government policies.\r\n\r\nEngineering and Technology Programs (Punjab Campus)\r\n\r\nThe Bachelor of Engineering (Computer Science Engineering \u2013 CSE) is a four-year degree program with a fee structure of \u20b91,50,000 per semester during the first two years and \u20b91,65,000 per semester in the final two years. The B.E. in CSE with a specialization in Artificial Intelligence and Machine Learning carries a fee of \u20b91,75,000 per semester for the first two years and \u20b91,92,500 per semester thereafter. The B.E. in CSE with Artificial Intelligence and Future Technologies specialization costs \u20b92,25,000 per semester for the first two years and \u20b92,47,500 per semester for the remaining years. The B.E.", "mimetype": "text/plain", "start_char_idx": 2045, "end_char_idx": 3069, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "8b26fad6-a475-419f-8cbb-7d20d040c1d0": {"__data__": {"id_": "8b26fad6-a475-419f-8cbb-7d20d040c1d0", "embedding": null, "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "8f30aa6e-a075-4914-85f6-e9333911418b", "node_type": "4", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "5ec2623a1e939294ad513db18bb59a532e60c37565fed9956bb7d0aa328cd00f", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "0182fd2b-0cfc-48a2-abfd-09a9e5267e3a", "node_type": "1", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "9d376aca04acb6e6eb2373bdfc7e26e6f56024aea57f60d15e6e0f2b43f37f17", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "a6380b11-b49d-42bc-a551-2082784759ea", "node_type": "1", "metadata": {}, "hash": "7fd6cf61e31ab189405ae387a69dcf94d9316f10b228756de3a23ecdfeba4f12", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "The B.E. programs in Electronics and Communication, Mechatronics, Mechanical, and Electrical Engineering have a fee of \u20b91,20,000 per semester for the first year and \u20b91,00,000 per semester from the second year onward. The B.E. in Automobile Engineering, offered in collaboration with ARAI, follows the same fee structure. The B.E. in Civil Engineering with specialization in AI & ML also follows the same pattern of \u20b91,20,000 and \u20b91,00,000 per semester respectively. Students opting for Mechanical or Electrical Engineering with a minor in Computer Science are charged \u20b91,30,000 per semester during the first year and \u20b91,10,000 per semester from the second year onward.\r\n\r\nEngineering and Technology Programs (Himachal Pradesh Campus)\r\nThe Bachelor of Engineering (Computer Science Engineering \u2013 CSE)in Himachal pradesh campus\r\nThe Himachal Pradesh campus offers a Bachelor of Engineering in Computer Science (B.E. CSE) as a four-year program.", "mimetype": "text/plain", "start_char_idx": 3061, "end_char_idx": 4003, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "a6380b11-b49d-42bc-a551-2082784759ea": {"__data__": {"id_": "a6380b11-b49d-42bc-a551-2082784759ea", "embedding": null, "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "8f30aa6e-a075-4914-85f6-e9333911418b", "node_type": "4", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "5ec2623a1e939294ad513db18bb59a532e60c37565fed9956bb7d0aa328cd00f", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "8b26fad6-a475-419f-8cbb-7d20d040c1d0", "node_type": "1", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "004f237ce4765bd96f97b42d0aaa00cee2939955fa08da4a3472fddcbe1b17cf", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "b765b7b0-1de8-484d-96b9-de7ab666cd5f", "node_type": "1", "metadata": {}, "hash": "047c0833c7e32addc2d5936a948f85e1799bd030f12b6888606207ffb91c15e4", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "CSE) as a four-year program. The eligibility criterion is Class XII with a minimum of 60% aggregate marks or 60% in Physics, Chemistry, and Mathematics, along with a valid JEE Mains 2025 score.\r\n The fee for this program is \u20b990,000 per semester across all eight semesters.\r\n\r\nComputer Applications Programs\r\n\r\nThe Bachelor of Computer Applications (BCA) with specialization in Artificial Intelligence and Machine Learning is a three-year undergraduate course. Eligibility requires completion of Class XII in any stream with at least 50% marks followed by an interview. The fee for the program is \u20b91,00,000 per semester across six semesters. The general BCA program also requires 10+2 with 50% marks in any stream and an interview, with a semester fee of \u20b965,000. The Master of Computer Applications (MCA) program is exclusively open to Chitkara University BCA graduates and spans two years, with a fee of \u20b995,000 per semester.", "mimetype": "text/plain", "start_char_idx": 3975, "end_char_idx": 4901, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "b765b7b0-1de8-484d-96b9-de7ab666cd5f": {"__data__": {"id_": "b765b7b0-1de8-484d-96b9-de7ab666cd5f", "embedding": null, "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "8f30aa6e-a075-4914-85f6-e9333911418b", "node_type": "4", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "5ec2623a1e939294ad513db18bb59a532e60c37565fed9956bb7d0aa328cd00f", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "a6380b11-b49d-42bc-a551-2082784759ea", "node_type": "1", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "1d95982dab5e7132ae1f8afd712f62e365fcc65c6c27ed7ea0864d356e143cca", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "213aea06-35f3-4f15-9759-c55a8f41185f", "node_type": "1", "metadata": {}, "hash": "0f5fc4b98287d68aa4e9549d23be1df8d4ad2d7aad4213a58adf010b3ce7f2c6", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Business and Management Programs\r\n\r\nThe Bachelor of Business Administration (BBA) is offered in multiple specializations including Professional, Retail, Logistics, FinTech & AI, Data Science & AI, Digital Transformation, and Aviation Management. Each of these programs runs for three years, with an optional fourth-year Honours extension.\r\nBBA in Professional\r\n\r\nThe Bachelor of Business Administration (Professional) program provides a comprehensive foundation in core business disciplines such as marketing, finance, human resources, and operations. It emphasizes practical exposure, case-based learning, and industry integration to develop strong managerial and entrepreneurial skills.\r\nDuration: 3 years (optional 4th-year Honours)\r\nEligibility: 10+2 in any stream with a minimum of 50% marks, followed by an interview.\r\nFees: \u20b970,000 for the first year and \u20b977,000 per semester thereafter, including Honours semesters.\r\n\r\nBBA in Retail Management\r\n\r\nThe BBA in Retail Management focuses on the study of retail operations, merchandising, consumer behavior, and supply chain strategies.", "mimetype": "text/plain", "start_char_idx": 4905, "end_char_idx": 5994, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "213aea06-35f3-4f15-9759-c55a8f41185f": {"__data__": {"id_": "213aea06-35f3-4f15-9759-c55a8f41185f", "embedding": null, "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "8f30aa6e-a075-4914-85f6-e9333911418b", "node_type": "4", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "5ec2623a1e939294ad513db18bb59a532e60c37565fed9956bb7d0aa328cd00f", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "b765b7b0-1de8-484d-96b9-de7ab666cd5f", "node_type": "1", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "31f558a91795a4ba9c03c58c3cf1d1c1d04afd7f4612760d68c1871b86a9634d", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "1297b84b-76de-47ec-88b6-3be1d8b21939", "node_type": "1", "metadata": {}, "hash": "dd89d2643b6e7f89f67dbddb574affe88bc7d776eec7edd29462a832fd29b719", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "It prepares students for leadership roles in retail chains, e-commerce, and customer relationship management.\r\nDuration: 3 years (optional 4th-year Honours)\r\nEligibility: 10+2 in any stream with at least 50% marks and an interview.\r\nFees: \u20b970,000 for the first year and \u20b977,000 per semester thereafter.\r\n\r\nBBA in Logistics Management\r\n\r\nThe BBA in Logistics Management specialization trains students in logistics, transportation, procurement, inventory management, and supply chain optimization. It equips them to handle global trade operations and logistics planning efficiently.\r\nDuration: 3 years (optional 4th-year Honours)\r\nEligibility: 10+2 (any stream) with minimum 50% marks, followed by an interview.\r\nFees: \u20b970,000 for the first year and \u20b977,000 per semester thereafter.\r\n\r\nBBA in FinTech & AI\r\n\r\nThe BBA in FinTech & AI blends financial management with emerging technologies like Artificial Intelligence, blockchain, and data analytics. Students learn digital finance systems, cryptocurrency trends, and AI-driven decision-making for modern financial institutions.", "mimetype": "text/plain", "start_char_idx": 5995, "end_char_idx": 7070, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "1297b84b-76de-47ec-88b6-3be1d8b21939": {"__data__": {"id_": "1297b84b-76de-47ec-88b6-3be1d8b21939", "embedding": null, "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "8f30aa6e-a075-4914-85f6-e9333911418b", "node_type": "4", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "5ec2623a1e939294ad513db18bb59a532e60c37565fed9956bb7d0aa328cd00f", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "213aea06-35f3-4f15-9759-c55a8f41185f", "node_type": "1", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "09bed4d605f04c7ab3b89f7fc1e323ce70bad0bf0c185d7a04712bac01cb0983", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "35d08661-35cf-4903-b083-e1924ee80f60", "node_type": "1", "metadata": {}, "hash": "b71480e291927db82c5d6608e389658428fa43ac72d3a89f1463f19dcbcce8b6", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Students learn digital finance systems, cryptocurrency trends, and AI-driven decision-making for modern financial institutions.\r\nDuration: 3 years (optional 4th-year Honours)\r\nEligibility: 10+2 in any stream with 50% marks, followed by an interview.\r\nFees: \u20b970,000 for the first year and \u20b977,000 per semester thereafter.\r\n\r\nBBA in Data Science & AI\r\n\r\nThe BBA in Data Science & AI focuses on analytics, data visualization, programming tools, and artificial intelligence applications for business intelligence and strategic planning. It prepares students for data-driven roles in various business sectors.\r\nDuration: 3 years (optional 4th-year Honours)\r\nEligibility: 10+2 (any stream) with a minimum of 50% marks and an interview.\r\nFees: \u20b970,000 for the first year and \u20b977,000 per semester thereafter.\r\n\r\nBBA in Digital Transformation\r\n\r\nThe BBA in Digital Transformation focuses on leveraging digital tools, automation, and analytics to modernize business operations. Students learn about e-commerce, digital marketing, and innovation-driven business models.", "mimetype": "text/plain", "start_char_idx": 6943, "end_char_idx": 8001, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "35d08661-35cf-4903-b083-e1924ee80f60": {"__data__": {"id_": "35d08661-35cf-4903-b083-e1924ee80f60", "embedding": null, "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "8f30aa6e-a075-4914-85f6-e9333911418b", "node_type": "4", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "5ec2623a1e939294ad513db18bb59a532e60c37565fed9956bb7d0aa328cd00f", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "1297b84b-76de-47ec-88b6-3be1d8b21939", "node_type": "1", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "e42c722cc78f0604bab8393f7ce8dae511976b861f06752c5c4ff590ea650de0", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "179feaf5-03fb-4cda-8135-91dddcdd141f", "node_type": "1", "metadata": {}, "hash": "9fac19d5bec9f1a402be76cf79304b9b8262a3dabbde0273e42f50da358b682d", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Students learn about e-commerce, digital marketing, and innovation-driven business models.\r\nDuration: 3 years (optional 4th-year Honours)\r\nEligibility: 10+2 in any stream with 50% marks, followed by an interview.\r\nFees: \u20b970,000 for the first year and \u20b977,000 per semester thereafter.\r\n\r\nBBA in Aviation Management\r\n\r\nThe BBA in Aviation Management equips students with knowledge of airline operations, airport management, safety protocols, and aviation regulations. It prepares graduates for managerial roles in airlines, airports, and related sectors.\r\nDuration: 3 years (optional 4th-year Honours)\r\nEligibility: 10+2 in any stream with 50% marks and an interview.\r\nFees: \u20b970,000 for the first year and \u20b977,000 per semester thereafter.\r\n\r\nGlobal Partnership Programs\r\n\r\nChitkara University offers several programs in collaboration with global institutions. The B.E. in Computer Science with Arizona State University is a four-year program with a fee of \u20b92,75,000 per semester during the first two years.", "mimetype": "text/plain", "start_char_idx": 7911, "end_char_idx": 8915, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "179feaf5-03fb-4cda-8135-91dddcdd141f": {"__data__": {"id_": "179feaf5-03fb-4cda-8135-91dddcdd141f", "embedding": null, "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "8f30aa6e-a075-4914-85f6-e9333911418b", "node_type": "4", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "5ec2623a1e939294ad513db18bb59a532e60c37565fed9956bb7d0aa328cd00f", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "35d08661-35cf-4903-b083-e1924ee80f60", "node_type": "1", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "69a06c64a79d7cecbdeb301c967d223b10664fbc33498473bb9010430d6084fd", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "70347ab9-23e5-43e0-95b5-4322f018b68f", "node_type": "1", "metadata": {}, "hash": "601da3ad8ba549e58059f7e9bb82b7e78fcd4c8c8c1d7331fa0dfa66a02b8e9d", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Students may either continue at Chitkara for \u20b91,65,000 per semester in later semesters or transfer to ASU. The BBA in Business Data Analytics or AI in Business, also offered in partnership with ASU, has a fee of \u20b92,50,000 per semester for the first two years and \u20b977,000 thereafter if continued at Chitkara. The B.E. in Software Engineering or AI & ML with Deakin University carries a fee of \u20b91,80,000 per semester for the first two years and \u20b91,65,000 thereafter. The B.Com (Hons) with the University of Windsor has a fee of \u20b91,80,000 per semester for the first two years and \u20b975,000 for the following years. The BBA and B.Sc. programs with George Brown College and Trent University follow the same pattern with \u20b91,80,000 per semester for the first two years and \u20b975,000 thereafter for continuing students.", "mimetype": "text/plain", "start_char_idx": 8916, "end_char_idx": 9723, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "70347ab9-23e5-43e0-95b5-4322f018b68f": {"__data__": {"id_": "70347ab9-23e5-43e0-95b5-4322f018b68f", "embedding": null, "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "8f30aa6e-a075-4914-85f6-e9333911418b", "node_type": "4", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "5ec2623a1e939294ad513db18bb59a532e60c37565fed9956bb7d0aa328cd00f", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "179feaf5-03fb-4cda-8135-91dddcdd141f", "node_type": "1", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "aa4af33611150cafa47bd5c3d891440401e399655d8bd3030ba66e492546319e", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "6e92b174-f6cc-41a6-903f-e40c76e0c6c9", "node_type": "1", "metadata": {}, "hash": "caba77456d413735c129bad27cb9477d97d06060e86586063189a59c41d5f2cf", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Health Sciences, Pharmacy & Professional Programs\r\n\r\nThe Bachelor of Science in Nursing (Basic) is a four-year degree program with fees of \u20b980,000 per semester at the Punjab campus and \u20b965,000 at the Himachal campus. The Bachelor of Pharmacy (B.Pharm) is a four-year course with fees of \u20b91,00,000 per semester at Punjab and \u20b970,000 per semester at Himachal. The Doctor of Pharmacy (Pharm.D) program spans six years, with fees of \u20b91,20,000 per semester during the first year and \u20b91,32,000 per semester thereafter. The Bachelor of Architecture (B.Arch) is a five-year program requiring Class XII (Science) with 45% marks and NATA qualification, with a fee of \u20b91,00,000 per semester. The Bachelor of Design (B.Des), available in Interior, Animation, Fashion, UX-UI, Communication, and Product Design specializations, is a four-year course requiring Class XII with 50% marks and CUDAT/UCEED qualification followed by an interview.", "mimetype": "text/plain", "start_char_idx": 9727, "end_char_idx": 10653, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "6e92b174-f6cc-41a6-903f-e40c76e0c6c9": {"__data__": {"id_": "6e92b174-f6cc-41a6-903f-e40c76e0c6c9", "embedding": null, "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "8f30aa6e-a075-4914-85f6-e9333911418b", "node_type": "4", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "5ec2623a1e939294ad513db18bb59a532e60c37565fed9956bb7d0aa328cd00f", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "70347ab9-23e5-43e0-95b5-4322f018b68f", "node_type": "1", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "1a83c1ec9192e4d6228da669f1109c799c131192aa97e55dd64d47b70ab2e82a", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "cdbbd83b-7c30-4848-b9bf-d4a9c9b85ffa", "node_type": "1", "metadata": {}, "hash": "17bfbd1071c98acc75be030b45906e1a674b562ef754893fad393f16e0c33844", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "The fee is \u20b91,50,000 per semester. The B.A. LLB (Hons) is a five-year integrated law degree open to Indian nationals who have completed Class XII with 50% marks, with a fee of \u20b91,00,000 per semester. The Bachelor of Education (B.Ed) is a two-year program with fees of \u20b940,000 per semester. Various other programs in allied health, hospitality, psychology, and media studies are also offered, with fees ranging from \u20b950,000 to \u20b91,75,000 per semester.\r\n\r\nCampus Facilities and Student Life\r\n\r\nChitkara University offers advanced infrastructure and facilities to ensure an enriching academic and personal experience. The university provides high-tech classrooms, digital libraries with access to databases like Science Direct and EBSCO, and modern laboratories for all disciplines. The entire campus is Wi-Fi enabled. The hostel facilities are secure and segregated for boys and girls, offering comfortable accommodation, common rooms, TV lounges, and high-speed internet.", "mimetype": "text/plain", "start_char_idx": 10654, "end_char_idx": 11623, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "cdbbd83b-7c30-4848-b9bf-d4a9c9b85ffa": {"__data__": {"id_": "cdbbd83b-7c30-4848-b9bf-d4a9c9b85ffa", "embedding": null, "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "8f30aa6e-a075-4914-85f6-e9333911418b", "node_type": "4", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "5ec2623a1e939294ad513db18bb59a532e60c37565fed9956bb7d0aa328cd00f", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "6e92b174-f6cc-41a6-903f-e40c76e0c6c9", "node_type": "1", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "cd490c787fea3133d53f952f2302dccd478fdd83174e89928b9865b3695c2823", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "6d3cc85e-bbb6-4a78-98a6-78d98e5cc2c0", "node_type": "1", "metadata": {}, "hash": "e2ac254417f3f0aeaf857c81ffdbab994479247db35c53d86556c785187642cd", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "The university also provides an extensive range of sports facilities, including cricket, football, basketball, tennis, badminton, and swimming pool facilities, along with fully equipped gyms. A 24-hour medical centre ensures round-the-clock healthcare, with all students covered under a comprehensive health insurance policy. Additional amenities include on-campus cafeterias, auditoriums, transport connectivity to nearby cities, and banking services with a UCO Bank counter and a 24/7 ATM.\r\n\r\nPlacements and Industry Collaboration\r\n\r\nChitkara University is known for its high placement records and deep industry integration. The university reports placement rates exceeding 90% in engineering and management programs. The 2023\u201324 academic year recorded a median salary of \u20b99.72 LPA for B.Tech students and \u20b911.5 LPA for MBA graduates. The highest packages for Computer Science graduates often exceed \u20b940 LPA. The university maintains over 300 corporate partnerships with organizations such as Microsoft, Amazon, Deloitte, Infosys, Google, Wipro, Cognizant, Bosch, Siemens, EY, and Fortis.", "mimetype": "text/plain", "start_char_idx": 11624, "end_char_idx": 12714, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "6d3cc85e-bbb6-4a78-98a6-78d98e5cc2c0": {"__data__": {"id_": "6d3cc85e-bbb6-4a78-98a6-78d98e5cc2c0", "embedding": null, "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "8f30aa6e-a075-4914-85f6-e9333911418b", "node_type": "4", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "5ec2623a1e939294ad513db18bb59a532e60c37565fed9956bb7d0aa328cd00f", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "cdbbd83b-7c30-4848-b9bf-d4a9c9b85ffa", "node_type": "1", "metadata": {"file_path": "D:\\Downloads\\Connect.Ai-main\\Connect.Ai-main\\pdf\\New Text Document.txt", "file_name": "New Text Document.txt", "file_type": "text/plain", "file_size": 13041, "creation_date": "2025-12-06", "last_modified_date": "2025-12-06"}, "hash": "0c9d9947e65717c1b1bafa95449cb8540fa23e079ef4c3562f131569bb2bd946", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "The Career Development Cell at Chitkara provides continuous support through resume workshops, interview training, mentorship, and internship placements to ensure students are fully industry-ready.", "mimetype": "text/plain", "start_char_idx": 12715, "end_char_idx": 12911, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}}, "docstore/metadata": {"8d5fecfd-e899-449e-9d1e-5ff6cbec99f6": {"doc_hash": "803a0e44860c154cb3fd903e55b10ecaed3032dd3bd2b7d21eab5a71da8471d4", "ref_doc_id": "8f30aa6e-a075-4914-85f6-e9333911418b"}, "17fc0a98-46e9-43c1-89f2-3f956a9d6a0b": {"doc_hash": "8e2661279e41440a02fe732d63ade4754008e4bd7c0fd6293bc08fd45ae9e86e", "ref_doc_id": "8f30aa6e-a075-4914-85f6-e9333911418b"}, "0182fd2b-0cfc-48a2-abfd-09a9e5267e3a": {"doc_hash": "9d376aca04acb6e6eb2373bdfc7e26e6f56024aea57f60d15e6e0f2b43f37f17", "ref_doc_id": "8f30aa6e-a075-4914-85f6-e9333911418b"}, "8b26fad6-a475-419f-8cbb-7d20d040c1d0": {"doc_hash": "004f237ce4765bd96f97b42d0aaa00cee2939955fa08da4a3472fddcbe1b17cf", "ref_doc_id": "8f30aa6e-a075-4914-85f6-e9333911418b"}, "a6380b11-b49d-42bc-a551-2082784759ea": {"doc_hash": "1d95982dab5e7132ae1f8afd712f62e365fcc65c6c27ed7ea0864d356e143cca", "ref_doc_id": "8f30aa6e-a075-4914-85f6-e9333911418b"}, "b765b7b0-1de8-484d-96b9-de7ab666cd5f": {"doc_hash": "31f558a91795a4ba9c03c58c3cf1d1c1d04afd7f4612760d68c1871b86a9634d", "ref_doc_id": "8f30aa6e-a075-4914-85f6-e9333911418b"}, "213aea06-35f3-4f15-9759-c55a8f41185f": {"doc_hash": "09bed4d605f04c7ab3b89f7fc1e323ce70bad0bf0c185d7a04712bac01cb0983", "ref_doc_id": "8f30aa6e-a075-4914-85f6-e9333911418b"}, "1297b84b-76de-47ec-88b6-3be1d8b21939": {"doc_hash": "e42c722cc78f0604bab8393f7ce8dae511976b861f06752c5c4ff590ea650de0", "ref_doc_id": "8f30aa6e-a075-4914-85f6-e9333911418b"}, "35d08661-35cf-4903-b083-e1924ee80f60": {"doc_hash": "69a06c64a79d7cecbdeb301c967d223b10664fbc33498473bb9010430d6084fd", "ref_doc_id": "8f30aa6e-a075-4914-85f6-e9333911418b"}, "179feaf5-03fb-4cda-8135-91dddcdd141f": {"doc_hash": "aa4af33611150cafa47bd5c3d89